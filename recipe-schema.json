{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SQL Recipe",
  "description": "Pre-built SQL analysis template for common data sources",
  "type": "object",
  "required": [
    "id",
    "name",
    "description",
    "data_source",
    "required_tables",
    "sql_template",
    "tier",
    "author",
    "version"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique recipe identifier (reverse-DNS style)",
      "pattern": "^[a-z0-9.-]+$",
      "example": "com.sery.shopify.churn-rate"
    },
    "name": {
      "type": "string",
      "description": "Human-readable recipe name",
      "maxLength": 100,
      "example": "Calculate Monthly Churn Rate"
    },
    "description": {
      "type": "string",
      "description": "What this recipe analyzes and why it's useful",
      "maxLength": 500,
      "example": "Analyzes customer purchase history to compute monthly churn rate. Identifies customers who made purchases in one month but not the next."
    },
    "data_source": {
      "type": "string",
      "description": "Primary data source this recipe targets",
      "enum": [
        "Shopify",
        "Stripe",
        "Google Analytics",
        "CSV",
        "Snowflake",
        "PostgreSQL",
        "MySQL",
        "Generic"
      ],
      "example": "Shopify"
    },
    "required_tables": {
      "type": "array",
      "description": "Tables/files that must exist for this recipe to run",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Table or file name (case-insensitive match)",
            "example": "orders"
          },
          "required_columns": {
            "type": "array",
            "description": "Columns that must exist in this table",
            "items": {
              "type": "string"
            },
            "example": ["customer_id", "order_date", "total"]
          }
        }
      },
      "minItems": 1,
      "example": [
        {
          "name": "orders",
          "required_columns": ["customer_id", "order_date"]
        }
      ]
    },
    "sql_template": {
      "type": "string",
      "description": "SQL query with {{parameter}} placeholders",
      "example": "SELECT DATE_TRUNC('month', order_date) AS month, COUNT(DISTINCT customer_id) AS customers FROM orders WHERE order_date >= '{{start_date}}' GROUP BY month"
    },
    "parameters": {
      "type": "array",
      "description": "User-configurable parameters for the SQL template",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Parameter name (used in {{name}} placeholders)",
            "example": "start_date"
          },
          "type": {
            "type": "string",
            "description": "Parameter data type",
            "enum": ["date", "int", "float", "string", "boolean"],
            "example": "date"
          },
          "label": {
            "type": "string",
            "description": "Human-readable label for UI",
            "example": "Start Date"
          },
          "description": {
            "type": "string",
            "description": "Help text explaining what this parameter does",
            "example": "Beginning of date range for analysis"
          },
          "default": {
            "description": "Default value (type depends on 'type' field)",
            "example": "30 days ago"
          },
          "validation": {
            "type": "object",
            "description": "Validation rules for this parameter",
            "properties": {
              "min": {
                "description": "Minimum value (for int/float/date)"
              },
              "max": {
                "description": "Maximum value (for int/float/date)"
              },
              "pattern": {
                "type": "string",
                "description": "Regex pattern (for string)"
              },
              "options": {
                "type": "array",
                "description": "Allowed values (for enum-like parameters)",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "default": []
    },
    "tier": {
      "type": "string",
      "description": "Access tier required to use this recipe",
      "enum": ["FREE", "PRO", "TEAM"],
      "example": "FREE"
    },
    "category": {
      "type": "string",
      "description": "Recipe category for organization",
      "enum": [
        "Revenue",
        "Customer Analytics",
        "Product Analytics",
        "Marketing",
        "Operations",
        "Finance",
        "General"
      ],
      "example": "Customer Analytics"
    },
    "tags": {
      "type": "array",
      "description": "Searchable tags",
      "items": {
        "type": "string"
      },
      "example": ["churn", "retention", "customers", "monthly"]
    },
    "author": {
      "type": "string",
      "description": "Recipe author (user or 'Sery Team')",
      "example": "Sery Team"
    },
    "version": {
      "type": "string",
      "description": "Semantic version",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "example": "1.0.0"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp",
      "example": "2024-01-15T00:00:00Z"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp",
      "example": "2024-01-15T00:00:00Z"
    },
    "metrics": {
      "type": "object",
      "description": "Community metrics",
      "properties": {
        "downloads": {
          "type": "integer",
          "minimum": 0,
          "example": 1234
        },
        "runs": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of times this recipe has been executed",
          "example": 5678
        },
        "rating": {
          "type": "number",
          "minimum": 0,
          "maximum": 5,
          "example": 4.8
        },
        "review_count": {
          "type": "integer",
          "minimum": 0,
          "example": 42
        }
      },
      "default": {
        "downloads": 0,
        "runs": 0,
        "rating": 0,
        "review_count": 0
      }
    },
    "example_output": {
      "type": "string",
      "description": "Markdown description of what the query returns",
      "example": "Returns a table with columns: `month` (YYYY-MM), `customers` (count of unique customers)"
    },
    "changelog_url": {
      "type": "string",
      "format": "uri",
      "description": "URL to recipe changelog",
      "example": "https://sery.ai/recipes/churn-rate/changelog"
    },
    "documentation_url": {
      "type": "string",
      "format": "uri",
      "description": "URL to recipe documentation",
      "example": "https://sery.ai/recipes/churn-rate"
    }
  }
}
